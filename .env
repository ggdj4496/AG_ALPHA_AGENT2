# --- CONFIGURACIÓN DE AGENTES DE SISTEMA ---
# Proveedor principal para bypass de cuota
OPENROUTER_API_KEY=tu_llave_aqui
ANYSCALE_API_KEY=tu_llave_aqui

# Modelos que aparecerán en el selector de Antigravity
MODEL_AGENT_CODER=deepseek/deepseek-chat:free
MODEL_AGENT_LOGIC=meta-llama/llama-3.3-70b-instruct:free
MODEL_AGENT_FAST=qwen/qwen-2.5-coder-32b-instruct:free

# Configuración de fallback automático
FALLBACK_PROVIDER=openrouter
